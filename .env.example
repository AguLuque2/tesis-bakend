# Copiar este archivo a ".env" y completar con los valores reales.
# El ".env" real NUNCA se sube al repositorio (ver .gitignore).

# Entorno: development | production | test
NODE_ENV=development

# Puerto en el que corre el servidor Express
PORT=3000

# --- Supabase ---
# URL del proyecto (Project Settings > API > Project URL)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clave "anon" (pública, segura para el cliente) — Project Settings > API
SUPABASE_ANON_KEY=

# Clave "service_role" (NUNCA exponer al frontend, NUNCA loguear)
# Project Settings > API > service_role secret
SUPABASE_SERVICE_ROLE_KEY=

# --- CORS ---
# Orígenes permitidos, separados por coma (ej: el dominio del frontend)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- Storage (documentos de obra) ---
# Bucket privado de Supabase Storage (ver migración documento_storage_bucket.sql)
SUPABASE_STORAGE_BUCKET_DOCUMENTOS=documentos
# Tamaño máximo de archivo permitido en la subida (MB)
DOCUMENTO_TAMANO_MAXIMO_MB=20
# Vigencia de la URL firmada de descarga (segundos)
DOCUMENTO_URL_DESCARGA_EXPIRA_SEGUNDOS=300
